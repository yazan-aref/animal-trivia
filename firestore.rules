rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - The user's Firebase Auth UID.
    //   - displayName: string (required) - The user's display name.
    //   - photoURL: string (required) - The user's profile photo URL.
    //   - score: number (required) - The user's total accumulated score.
    //   - quizzesCompleted: number (required) - The total number of quizzes completed.
    //   - timestamp: timestamp (required) - The time the score was achieved.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Domain Validators
    function isValidLeaderboardEntry() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'score', 'quizzesCompleted', 'timestamp']) &&
             hasRequiredFields(['uid', 'displayName', 'photoURL', 'score', 'quizzesCompleted', 'timestamp']) &&
             request.resource.data.uid is string &&
             request.resource.data.displayName is string && request.resource.data.displayName.size() > 0 && request.resource.data.displayName.size() < 100 &&
             request.resource.data.photoURL is string && isValidUrl(request.resource.data.photoURL) && request.resource.data.photoURL.size() < 500 &&
             request.resource.data.score is number && request.resource.data.score >= 0 &&
             request.resource.data.quizzesCompleted is number && request.resource.data.quizzesCompleted >= 0 &&
             request.resource.data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard/{userId} {
      // Anyone can read the leaderboard to see top scores
      allow read: if true;
      
      // Users can only create or update their own score
      allow create: if isOwner(userId) && isValidLeaderboardEntry() && uidUnchanged();
      allow update: if isOwner(userId) && isValidLeaderboardEntry() && uidNotModified() && 
                    // Ensure they don't change their UID
                    request.resource.data.uid == resource.data.uid;
    }
  }
}
