{
  "entities": {
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "A user's top score in the Animal Wordle Game.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "score": {
          "type": "number",
          "description": "The user's total score."
        },
        "gamesPlayed": {
          "type": "number",
          "description": "The total number of games the user has played."
        },
        "gamesWon": {
          "type": "number",
          "description": "The total number of games the user has won."
        },
        "currentStreak": {
          "type": "number",
          "description": "The user's current win streak."
        },
        "maxStreak": {
          "type": "number",
          "description": "The user's maximum win streak."
        },
        "timestamp": {
          "type": "timestamp",
          "description": "The time the score was achieved."
        }
      },
      "required": ["uid", "displayName", "photoURL", "score", "gamesPlayed", "gamesWon", "currentStreak", "maxStreak", "timestamp"]
    },
    "QuizHistoryEntry": {
      "title": "QuizHistoryEntry",
      "description": "A record of an individual quiz attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "timestamp" },
        "score": { "type": "number" },
        "mode": { "type": "string" },
        "totalQuestions": { "type": "number" },
        "correctAnswers": { "type": "number" },
        "questionsSummary": { "type": "object" }
      },
      "required": ["userId", "date", "score", "mode", "totalQuestions", "correctAnswers"]
    }
  },
  "firestore": {
    "/leaderboard/{userId}": {
      "schema": {
        "$ref": "#/entities/LeaderboardEntry"
      },
      "description": "Stores the highest score for each user."
    },
    "/quizHistory/{entryId}": {
      "schema": {
        "$ref": "#/entities/QuizHistoryEntry"
      },
      "description": "Stores individual quiz attempt records."
    }
  }
}
