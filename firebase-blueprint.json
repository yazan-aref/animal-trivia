{
  "entities": {
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "A user's top score in the Animal Trivia Game.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "score": {
          "type": "number",
          "description": "The user's highest score."
        },
        "quizzesCompleted": {
          "type": "number",
          "description": "The total number of quizzes the user has completed."
        },
        "stats": {
          "type": "object",
          "description": "User statistics.",
          "properties": {
            "totalCorrect": { "type": "number" },
            "maxStreak": { "type": "number" },
            "marathonHighScore": { "type": "number" }
          }
        },
        "achievements": {
          "type": "array",
          "description": "List of earned achievement IDs.",
          "items": { "type": "string" }
        },
        "timestamp": {
          "type": "timestamp",
          "description": "The time the score was achieved."
        }
      },
      "required": ["uid", "displayName", "photoURL", "score", "quizzesCompleted", "timestamp"]
    },
    "QuizHistoryEntry": {
      "title": "QuizHistoryEntry",
      "description": "A record of a completed quiz session.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "date": {
          "type": "timestamp",
          "description": "The time the quiz was completed."
        },
        "score": {
          "type": "number",
          "description": "The final score of the quiz."
        },
        "mode": {
          "type": "string",
          "description": "The game mode played (e.g., classic, marathon)."
        },
        "totalQuestions": {
          "type": "number",
          "description": "Total number of questions answered."
        },
        "correctAnswers": {
          "type": "number",
          "description": "Number of questions answered correctly."
        },
        "questionsSummary": {
          "type": "array",
          "description": "Summary of each question answered.",
          "items": {
            "type": "object",
            "properties": {
              "questionText": { "type": "string" },
              "isCorrect": { "type": "boolean" },
              "userAnswer": { "type": "string" },
              "correctAnswer": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "date", "score", "mode", "totalQuestions", "correctAnswers", "questionsSummary"]
    }
  },
  "firestore": {
    "/leaderboard/{userId}": {
      "schema": {
        "$ref": "#/entities/LeaderboardEntry"
      },
      "description": "Stores the highest score for each user."
    },
    "/quizHistory/{entryId}": {
      "schema": {
        "$ref": "#/entities/QuizHistoryEntry"
      },
      "description": "Stores individual quiz session history for users."
    }
  }
}
